{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui-tauri-template/main/src-tauri/gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "shell:allow-open",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit"
  ]
}
